{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],
  "additionalBranchPrefix": "{{parentDir}}-",
  "assignees": ["christianhuth"],
  "bumpVersion": "patch",
  "labels": ["renovate"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^charts/gateway-api-crds/Chart\\.yaml$/"],
      "matchStrings": ["appVersion:\\s*\"(?<currentValue>v[\\d.]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes-sigs/gateway-api"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["helmv3"],
      "postUpgradeTasks": {
        "commands": ["bash ./renovate-update-chart-dependency.sh '{{{parentDir}}}' '{{{updateType}}}' '{{{depName}}}' '{{{newValue}}}'"],
        "executionMode": "branch"
      }
    },
    {
      "matchManagers": ["helm-values"],
      "postUpgradeTasks": {
        "commands": ["bash ./renovate-update-chart-values.sh '{{{parentDir}}}' '{{{updateType}}}' '{{{currentValue}}}' '{{{newValue}}}'"],
        "executionMode": "branch"
      }
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["kubernetes-sigs/gateway-api"],
      "postUpgradeTasks": {
        "commands": ["bash ./renovate-update-gateway-api-crds.sh '{{{updateType}}}' '{{{currentValue}}}' '{{{newValue}}}'"],
        "executionMode": "branch"
      }
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    }
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "timezone": "Europe/Berlin"
}
